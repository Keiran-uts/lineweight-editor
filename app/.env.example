# Copy this file to `.env` and fill in your values. `.env` is gitignored.
#
# The Illustrator MCP token is shown when you register the server with
# `claude mcp add` (it changes whenever the MCP server restarts). You can
# instead provide the full header via ILLUSTRATOR_MCP_AUTH.
#
# If you leave this unset, the app falls back to reading the token from
# ~/.claude.json (mcpServers.illustrator).

ILLUSTRATOR_MCP_URL=http://localhost:18412/v1/mcp
ILLUSTRATOR_MCP_TOKEN=ilst_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ILLUSTRATOR_MCP_AUTH=Bearer ilst_xxxxxxxx   # alternative to TOKEN
